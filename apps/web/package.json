{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port=3001",
    "build": "vite build",
    "test": "bun test --preload ./src/test/setup.ts --dom",
    "test:watch": "bun test --watch --preload ./src/test/setup.ts --dom",
    "test:coverage": "bun test --coverage --preload ./src/test/setup.ts --dom",
    "serve": "vite preview",
    "start": "vite",
    "check-types": "tsc --noEmit",
    "wrangler": "wrangler",
    "wrangler:dev": "wrangler dev --port=3001",
    "wrangler:dev:multi": "wrangler dev --config wrangler.jsonc --config ../server/wrangler.jsonc --port=3001",
    "deploy": "bun run build && wrangler deploy",
    "deploy:dry-run": "bun run build && wrangler deploy --dry-run"
  },
  "dependencies": {
